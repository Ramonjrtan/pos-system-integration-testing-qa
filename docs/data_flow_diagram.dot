
digraph F {
  graph [dpi=180, bgcolor="white", rankdir=LR, pad=0.2, nodesep=0.55, ranksep=0.9];
  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=12, color="#1F4E78", penwidth=1.1, margin="0.18,0.10"];
  edge [fontname="Arial", fontsize=10, color="#5B9BD5", penwidth=1.2, arrowsize=0.8];
  Start [label="1. Start Transaction", fillcolor="#D9EAF7"];
  Scan [label="2. Scan Items / Card / DL", fillcolor="#D9EAF7"];
  Rules [label="3. ACS Business Rules\nQuantity / Promo / Receipt / Return Logic", fillcolor="#E2F0D9"];
  External [label="4. External Calls\nEFT | External Host Service | Gift Card Provider", fillcolor="#FCE4D6"];
  Finalize [label="5. Finalize Sale or Return", fillcolor="#D9EAF7"];
  Outputs [label="6. Outputs\nReceipt | Status Message | Cashier Guidance", fillcolor="#FFF2CC"];
  Tlog [label="7. Persist Audit Data\nAudit Log / Journal / Reconciliation", fillcolor="#FFF2CC"];
  Verify [label="8. QA Validation\nUI + API + Receipt + Audit Log", fillcolor="#DDEBF7"];
  Start -> Scan -> Rules -> External -> Finalize -> Outputs -> Tlog -> Verify;
  Retry [label="Timeout / Decline / Recovery Path", fillcolor="#FDE9E7"];
  External -> Retry [label="negative path"];
  Retry -> Rules [label="retry / fallback / block"];
}
