
digraph G {
  graph [dpi=180, bgcolor="white", rankdir=LR, pad=0.2, nodesep=0.45, ranksep=0.8];
  node [shape=box, style="rounded,filled", fontname="Arial", fontsize=12, color="#1F4E78", penwidth=1.2, margin="0.18,0.10"];
  edge [fontname="Arial", fontsize=10, color="#5B9BD5", penwidth=1.2, arrowsize=0.8];
  subgraph cluster_lane {
    label="Store Lane"; color="#9CC2E5"; style="rounded";
    POS [label="POS Terminal\nSale / Return / Void", fillcolor="#D9EAF7"];
    Devices [label="Lane Devices\nScanner | PIN Pad | Printer | DynaKey", fillcolor="#EAF3FB"];
  }
  subgraph cluster_store {
    label="Store Services"; color="#A9D18E"; style="rounded";
    ACS [label="Commerce Platform 7.0 Services\nPricing | Tendering | Receipt Logic", fillcolor="#E2F0D9"];
    Config [label="WebOffice / Configuration", fillcolor="#FCE4D6"];
    Audit Log [label="Audit Log / Audit Store", fillcolor="#FFF2CC"];
  }
  subgraph cluster_external {
    label="External Integrations"; color="#F4B183"; style="rounded";
    EFT [label="EFT Gateway", fillcolor="#FCE4D6"];
    External Host Service [label="External Host Service Host Services", fillcolor="#FCE4D6"];
    BH [label="Gift Card Provider Gift Card Network", fillcolor="#FCE4D6"];
  }
  subgraph cluster_ops {
    label="Downstream / QA Observability"; color="#C9C9C9"; style="rounded";
    Reports [label="Reporting / Reconciliation", fillcolor="#E7E6E6"];
    QA [label="QA Validation Points\nUI | API | Audit Log | Receipt", fillcolor="#DDEBF7"];
  }
  Devices -> POS [label="operator input"];
  POS -> ACS [label="transaction events"];
  Config -> ACS [label="feature flags / settings"];
  ACS -> EFT [label="authorize / capture"];
  ACS -> External Host Service [label="tender & host services"];
  ACS -> BH [label="activate / reload"];
  ACS -> Audit Log [label="audit writes"];
  Audit Log -> Reports [label="downstream feed"];
  POS -> QA [label="UI / receipt checks"];
  EFT -> QA [label="API assertions", style=dashed];
  Audit Log -> QA [label="data integrity", style=dashed];
}
